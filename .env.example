# ──────────────────────────────────────────────────────────────
# Local environment contract for the Collaborative Code Editor
#
# Copy this file to .env and fill in any values marked with a
# note before running `docker compose up`.
# ──────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# JDBC URL for the PostgreSQL container defined in docker-compose.yml.
APP_DB_URL=jdbc:postgresql://postgres:5432/collabeditor
APP_DB_USERNAME=collabeditor
APP_DB_PASSWORD=collabeditor

# ── Redis ─────────────────────────────────────────────────────
# Hostname and port of the Redis container.
APP_REDIS_HOST=redis
APP_REDIS_PORT=6379

# ── JWT Auth ──────────────────────────────────────────────────
# HMAC-SHA signing secret for access tokens.
# Must be non-empty and at least 32 characters; the app fails
# to start if this is absent or too short.
APP_JWT_SECRET=change-this-to-at-least-32-characters

# ── Docker socket ─────────────────────────────────────────────
# Host path to the Docker daemon socket.
# Mounted into the app container so Phase 4 sandbox execution
# can reach the host Docker daemon.
# Override this for non-default local runtimes such as Colima:
#   DOCKER_SOCKET_PATH=$HOME/.colima/default/docker.sock
DOCKER_SOCKET_PATH=/var/run/docker.sock
